# Sir Interruptsalot — backend environment variables
# Copy this file to `.env` and fill in real keys. Never commit `.env`.

# Anthropic Claude API — required (rebuttal generation, judging, persona report)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Serper Google Search API — required (source-grounded rebuttals)
# Get one at https://serper.dev/
SERPER_API_KEY=
